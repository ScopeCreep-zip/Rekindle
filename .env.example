# Rekindle development environment defaults
# Copy to .env for local overrides (not committed)
#
# Setup: cp .env.example .env

# Use the plain docker driver for buildx to avoid NVIDIA container runtime
# hook failures when the host has a driver/library version mismatch.
BUILDX_BUILDER=default

# Tracing filter for rekindle nodes (applied to all container services).
# Override in .env to increase veilid_core verbosity for debugging:
#   RUST_LOG=info,rekindle=debug,veilid_core=info
RUST_LOG=info,rekindle=debug,veilid_core=warn
