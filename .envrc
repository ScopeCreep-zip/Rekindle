# Rekindle development environment
# Setup: direnv allow

# ── Rust toolchain ────────────────────────────────────────────────────
# Ensure cargo/rustc are on PATH when using rustup
if [[ -f "$HOME/.cargo/env" ]]; then
  source "$HOME/.cargo/env"
fi

# ── Build configuration ──────────────────────────────────────────────
# Force libsodium-sys-stable to link against system libsodium via
# pkg-config instead of building from source.
export SODIUM_USE_PKG_CONFIG=1

# ── Nix flake (uncomment to use Nix devshell instead of host deps) ───
# use flake
#
# # Prepend Rekindle's Nix-provided runtime libraries (libsodium, libopus, libasound)
# # to LD_LIBRARY_PATH. REKINDLE_LIB_PATH is set via flake.nix env attribute.
# if [[ -n "$REKINDLE_LIB_PATH" ]]; then
#   export LD_LIBRARY_PATH="${REKINDLE_LIB_PATH}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
# fi
#
# # ── Nix + WebKitGTK EGL workaround ───────────────────────────────────
# # Nix-built WebKitGTK links against Nix's libglvnd, which can't load
# # host GPU drivers (ABI mismatch). Disable accelerated compositing so
# # WebKitGTK never calls eglGetDisplay(). This only affects dev builds
# # run from the Nix shell — release builds use host system libs and get
# # full GPU acceleration.
# #
# # See: https://github.com/tauri-apps/tauri/issues/9394
# #      https://github.com/nix-community/nixGL (proper fix for future)
# if [[ "$(uname)" == "Linux" ]]; then
#   export WEBKIT_DISABLE_COMPOSITING_MODE=1
# fi
